---
import PageLayout from "@layouts/PageLayout.astro";
import LegalNotice from "@components/layout/LegalNotice.astro";
import { breadcrumbListSchema } from "@lib/schema";

const title = "Cookie Policy | M2VPRODUCTION";
const description = "How M2VPRODUCTION uses cookies on this website, and how to control them.";
---

<PageLayout
  title={title}
  description={description}
  path="/legal/cookie-policy"
  breadcrumbs={[{ label: "Cookie Policy" }]}
  extraSchema={[breadcrumbListSchema([{ name: "Cookie Policy", path: "/legal/cookie-policy" }])]}
>
  <section class="section legal">
    <div class="container container-narrow">
      <h1>Cookie Policy</h1>
      <LegalNotice />

      <h2>What are cookies</h2>
      <p>
        Cookies are small text files stored on your device that help websites
        function and, where permitted, understand how they're used.
      </p>

      <h2>Cookies we use</h2>
      <p>
        <strong>Essential:</strong> used for core site functionality (e.g. remembering
        your cookie consent choice). These cannot be disabled and don't require consent.
      </p>
      <p>
        <strong>Analytics:</strong> used to understand site traffic and improve the
        site, only loaded after you accept cookies via the banner on this site. See
        the TODO in src/layouts/BaseLayout.astro — analytics scripts (GA4/GTM) are not
        yet configured with real tracking IDs and are not active in this build.
      </p>

      <h2>Managing cookies</h2>
      <p>
        You can change your consent choice at any time by clearing the
        "m2v_cookie_consent" entry in your browser's local storage for this site, or
        by using your browser's cookie settings to block cookies entirely.
      </p>
    </div>
  </section>
</PageLayout>

<style>
  .legal { padding-block: var(--space-9); }
  .container-narrow { max-width: 720px; }
  h1 { font-family: var(--font-serif); font-size: 34px; color: var(--ink); margin-bottom: var(--space-6); }
  h2 { font-family: var(--font-serif); font-size: 19px; color: var(--ink); margin-top: var(--space-7); margin-bottom: var(--space-3); }
  p { font-size: 14.5px; line-height: 1.7; color: var(--text-muted); margin-bottom: var(--space-3); }
</style>
