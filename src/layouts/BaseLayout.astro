---
import "@styles/global.css";
import { resolveCanonical, resolveOgImage } from "@lib/seo";
import { localBusinessSchema } from "@lib/schema";
import CookieBanner from "@components/layout/CookieBanner.astro";

export interface Props {
  title: string;
  description: string;
  path: string;
  ogImage?: string;
  noindex?: boolean;
  /** Extra JSON-LD schema objects for this specific page (FAQPage, BreadcrumbList, etc.) */
  extraSchema?: object[];
}

const { title, description, path, ogImage, noindex = false, extraSchema = [] } = Astro.props;

const canonical = resolveCanonical(path);
const ogImageUrl = resolveOgImage(ogImage);
const schemas = [localBusinessSchema(), ...extraSchema];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="M2VPRODUCTION" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- JSON-LD structured data -->
    {schemas.map((schema: object) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <link rel="icon" href="/favicons/favicon-32x32.png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/favicons/apple-touch-icon-180x180.png" />
    <link rel="alternate" type="application/rss+xml" title="M2VPRODUCTION Journal" href="/rss.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!--
      TODO — Phase 3/F analytics plan: GA4 / GTM / Meta Pixel / LinkedIn Insight Tag
      loaders go here, but MUST be gated behind cookie consent (see CookieBanner.astro
      and src/lib below). Do not add these <script> tags unhydrated/unconditional —
      that was flagged as a compliance requirement in Phase H (Cookie Policy outline).
      Real IDs are read from PUBLIC_GA4_MEASUREMENT_ID etc. in .env — see .env.example.
    -->
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <slot />
    <CookieBanner />
  </body>
</html>
