---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import MediaBlock from "@components/media/MediaBlock.astro";
import { pageSeoRegistry } from "@lib/seo";
import { breadcrumbListSchema } from "@lib/schema";

const seo = pageSeoRegistry.journal;

const posts = (await getCollection("journal")).sort(
  (a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf()
);
---

<PageLayout
  title={seo.title}
  description={seo.description}
  path={seo.path}
  breadcrumbs={[{ label: "Journal" }]}
  extraSchema={[breadcrumbListSchema([{ name: "Journal", path: "/journal" }])]}
>
  <section class="section hero">
    <div class="container hero-inner">
      <p class="eyebrow">Journal</p>
      <h1>Field notes on permits, locations and production in Tanzania.</h1>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {posts.length > 0 ? (
        <div class="post-grid">
          {posts.map((post) => (
            <a href={`/journal/${post.slug}`} class="post-card">
              <MediaBlock src={post.data.coverImage} alt={post.data.coverImageAlt} ratio="4/3" />
              <p class="category">{post.data.category}</p>
              <h2>{post.data.title}</h2>
              <p class="excerpt">{post.data.excerpt}</p>
              {!post.data.isVerified && <span class="badge">Draft — pending fact-check</span>}
            </a>
          ))}
        </div>
      ) : (
        <p class="pending-note">Journal articles are in progress — check back soon.</p>
      )}
    </div>
  </section>
</PageLayout>

<style>
  .hero { padding-block: var(--space-8); }
  .hero-inner { max-width: 640px; }
  .eyebrow { font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--gold-ink); margin-bottom: var(--space-4); }
  h1 { font-family: var(--font-serif); font-size: 34px; line-height: 1.2; color: var(--ink); }
  .post-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  .post-card { display: block; color: inherit; }
  .category { font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--gold-ink); margin-top: var(--space-3); }
  .post-card h2 { font-family: var(--font-serif); font-size: 19px; color: var(--ink); margin: var(--space-2) 0; }
  .excerpt { font-size: 13.5px; color: var(--text-muted); line-height: 1.6; }
  .badge { display: inline-block; margin-top: var(--space-3); font-size: 11px; color: #8a7550; font-style: italic; }
  .pending-note { font-size: 14px; color: var(--text-muted); }
  @media (max-width: 1024px) { .post-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 640px) { .post-grid { grid-template-columns: 1fr; } }
</style>
