---
import { siteMeta, contactDetails } from "@data/siteConfig";
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container top">
    <div class="brand-col">
      <p class="tagline">{siteMeta.tagline}</p>
      <p class="addr">{siteMeta.addressLocality}, Tanzania</p>

      <form class="newsletter" id="newsletter-form" novalidate>
        <label for="newsletter-email">Get field notes on permits, locations and production in Tanzania.</label>
        <input type="email" id="newsletter-email" name="email" placeholder="Your email" autocomplete="email" required />
        <button type="submit" class="btn btn-gold">Subscribe</button>
        <p class="form-msg" id="newsletter-msg" role="status" aria-live="polite"></p>
      </form>
    </div>

    <nav aria-label="Services">
      <h2>Services</h2>
      <a href="/film-production">Film Production</a>
      <a href="/corporate-media">Corporate Media</a>
      <a href="/film-fixing-tanzania">Film Fixing Tanzania</a>
      <a href="/equipment">Equipment</a>
    </nav>

    <nav aria-label="Company">
      <h2>Company</h2>
      <a href="/about">About</a>
      <a href="/portfolio">Portfolio</a>
      <a href="/clients">Clients</a>
      <a href="/contact">Contact</a>
    </nav>

    <div aria-label="Contact">
      <h2>Contact</h2>
      <p>
        {contactDetails.email.verified
          ? <a href={`mailto:${contactDetails.email.value}`}>{contactDetails.email.value}</a>
          : <span class="todo-flag" title={contactDetails.email.todo}>Email — pending verification</span>}
      </p>
      <p>{siteMeta.addressLocality}, Tanzania</p>
    </div>
  </div>

  <div class="container footer-bottom">
    <span>&copy; {year} M2VPRODUCTION. All rights reserved.</span>
    <span class="legal-links">
      <a href="/legal/privacy-policy">Privacy Policy</a>
      <a href="/legal/terms">Terms of Service</a>
      <a href="/legal/accessibility-statement">Accessibility</a>
    </span>
  </div>
</footer>

<script>
  const form = document.getElementById("newsletter-form") as HTMLFormElement | null;
  const msg = document.getElementById("newsletter-msg");
  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const input = document.getElementById("newsletter-email") as HTMLInputElement | null;
    if (!input || !msg) return;
    if (!EMAIL_RE.test(input.value.trim())) {
      msg.textContent = "Enter a valid email to subscribe.";
      msg.dataset.state = "error";
      return;
    }
    // TODO: wire to a real newsletter provider (see Phase F Newsletter Strategy).
    // No backend exists for this yet — this is a client-side stub only.
    msg.textContent = "You're on the list — first dispatch soon.";
    msg.dataset.state = "success";
    input.value = "";
  });
</script>

<style>
  .site-footer {
    background: var(--ink);
    color: #b9b3a8;
    padding: var(--space-8) 0 var(--space-6);
  }
  .top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-7);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  .tagline { font-family: var(--font-serif); font-size: 22px; color: #fff; margin-bottom: var(--space-3); }
  .addr { font-size: 12.5px; margin-bottom: var(--space-5); }
  .newsletter label { display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-2); color: #8a8478; }
  .newsletter input {
    width: 100%;
    padding: 11px 12px;
    border-radius: var(--radius-md);
    border: 1px solid #444;
    background: #1e1e1e;
    color: #fff;
    font-size: 13px;
    margin-bottom: var(--space-3);
  }
  .btn.btn-gold {
    width: 100%;
    justify-content: center;
    padding: 11px;
    background: var(--gold2);
    color: var(--ink);
    border: none;
    border-radius: var(--radius-md);
    font-weight: 700;
    font-size: 12.5px;
    text-transform: uppercase;
    cursor: pointer;
  }
  .form-msg { font-size: 12px; margin-top: var(--space-2); min-height: 16px; }
  .form-msg[data-state="error"] { color: #e08a7a; }
  .form-msg[data-state="success"] { color: #a8d0a0; }

  nav h2, [aria-label="Contact"] h2 {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #8a8478;
    margin-bottom: var(--space-4);
    font-family: var(--font-sans);
    font-weight: 700;
  }
  nav a, [aria-label="Contact"] a {
    display: block;
    font-size: 13px;
    padding: var(--space-2) 0;
    color: #b9b3a8;
  }
  nav a:hover, [aria-label="Contact"] a:hover { color: #fff; }
  .todo-flag { font-size: 12px; color: #8a7550; font-style: italic; }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    padding-top: var(--space-5);
    font-size: 12px;
    color: #8a8478;
    flex-wrap: wrap;
    gap: var(--space-3);
  }
  .legal-links a { display: inline; padding: 0; margin-right: var(--space-4); color: #8a8478; }
  .legal-links a:hover { color: #fff; }

  @media (max-width: 1024px) {
    .top { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 640px) {
    .top { grid-template-columns: 1fr; }
  }
</style>
