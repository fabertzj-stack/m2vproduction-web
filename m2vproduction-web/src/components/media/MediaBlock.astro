---
// MediaBlock.astro — generic responsive image block with a mandatory alt requirement
// (TypeScript will error at build time if alt is omitted — see Props). Uses native
// lazy-loading and async decoding by default; set `priority` for above-the-fold images
// (hero, LCP candidates) to opt out of lazy-loading and hint eager fetch.
export interface Props {
  src: string;
  alt: string;
  caption?: string;
  ratio?: "16/9" | "4/3" | "1/1" | "3/4" | "auto";
  priority?: boolean;
}
const { src, alt, caption, ratio = "16/9", priority = false } = Astro.props;
const isTodo = src.startsWith("/TODO") || src.startsWith("TODO");
---

<figure class:list={["media-block", `ratio-${ratio.replace("/", "-")}`]}>
  {isTodo ? (
    <div class="todo-placeholder" role="img" aria-label={alt}>
      <span>{alt}</span>
    </div>
  ) : (
    <img
      src={src}
      alt={alt}
      loading={priority ? "eager" : "lazy"}
      decoding="async"
      fetchpriority={priority ? "high" : "auto"}
    />
  )}
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .media-block {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: var(--warmgrey);
  }
  .media-block img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .ratio-16-9 { aspect-ratio: 16 / 9; }
  .ratio-4-3 { aspect-ratio: 4 / 3; }
  .ratio-1-1 { aspect-ratio: 1 / 1; }
  .ratio-3-4 { aspect-ratio: 3 / 4; }
  .ratio-auto { aspect-ratio: auto; }

  .todo-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: repeating-linear-gradient(
      45deg,
      #e8e2d4,
      #e8e2d4 10px,
      #ddd6c4 10px,
      #ddd6c4 20px
    );
    padding: var(--space-4);
  }
  .todo-placeholder span {
    font-size: 12px;
    color: #6b6552;
    text-align: center;
    font-style: italic;
    max-width: 80%;
  }
  figcaption {
    font-size: 12px;
    color: var(--text-muted);
    margin-top: var(--space-2);
  }
</style>
